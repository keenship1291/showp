# ============================================================
# Ad Creative Server — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

PORT=3000
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
# This same key goes into chrome-extension/config.js VPS_API_KEY
API_KEY=replace_with_a_random_64_char_hex_string

# ── Redis (auto-configured in docker-compose) ─────────────────
REDIS_URL=redis://redis:6379

# ── LLM (Claude via Kie.ai proxy) ────────────────────────────
# Used for product analysis + concept generation
# IMPORTANT: use /claude/v1 endpoint (NOT /api/v1 — that is image-only)
LLM_BASE_URL=https://api.kie.ai/claude/v1
LLM_MODEL=claude-sonnet-4-6

# ── Kie.ai (Banana image generation) ─────────────────────────
# Get your API key from: https://kie.ai/ → API Keys
KIE_AI_API_KEY=your_kie_ai_api_key_here
KIE_AI_BASE_URL=https://api.kie.ai/api/v1
KIE_AI_MODEL=nano-banana-2
# Kie.ai File Upload API — used to pre-upload product reference images
# before passing them to the image generation task (required by Kie.ai)
KIE_AI_UPLOAD_BASE_URL=https://kieai.redpandaai.co

# ── Server public URL ─────────────────────────────────────────
# Your VPS domain — used to build image URLs returned to the extension
# Example: https://ads.yourdomain.com  OR  http://123.45.67.89:3000
IMAGE_BASE_URL=https://ads.yourdomain.com

# ── Generation tuning ─────────────────────────────────────────
CONCURRENT_GENERATIONS=3
POLL_INTERVAL_MS=5000
POLL_TIMEOUT_MS=300000

# Job state TTL in Redis (default: 1800 = 30 minutes)
JOB_TTL_SECONDS=1800
